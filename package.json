{
  "name": "bununban",
  "version": "0.3.0",
  "type": "module",
  "module": "src/index.js",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development bun --hot run ./src/index.js",
    "dev:setup": "bun run build:windows-x64 && NODE_ENV=development bun --watch run ./setup/index.js",
    "build": "bun run clear:dist && bun run build:windows-x64 && bun run build:windows-x64-no-simd && bun run build:linux-x64 && bun run build:linux-x64-no-simd && bun run build:linux-x64-musl && bun run build:linux-x64-musl-no-simd && bun run build:linux-arm64 && bun run build:linux-arm64-musl && bun run build:setup",
    "build:windows-x64": "bun build ./src/index.js --compile --production --target=bun-windows-x64-modern --minify --outfile dist/bununban-windows-x64 --windows-icon=\"./src/frontend/assets/favicon.ico\" --windows-hide-console --windows-title=bununban --windows-publisher=Greezor --windows-version=0.3.0 --windows-description=Bununban && bun win-fix/modify-binary.js ./dist/bununban-windows-x64.exe",
    "build:windows-x64-no-simd": "bun build ./src/index.js --compile --production --target=bun-windows-x64-baseline --minify --outfile dist/bununban-windows-x64-no-simd --windows-icon=\"./src/frontend/assets/favicon.ico\" --windows-hide-console --windows-title=bununban --windows-publisher=Greezor --windows-version=0.3.0 --windows-description=Bununban && bun win-fix/modify-binary.js ./dist/bununban-windows-x64-no-simd.exe",
    "build:linux-x64": "bun build ./src/index.js --compile --production --target=bun-linux-x64-modern --minify --outfile dist/bununban-linux-x64",
    "build:linux-x64-no-simd": "bun build ./src/index.js --compile --production --target=bun-linux-x64-baseline --minify --outfile dist/bununban-linux-x64-no-simd",
    "build:linux-x64-musl": "bun build ./src/index.js --compile --production --target=bun-linux-x64-musl-modern --minify --outfile dist/bununban-linux-x64-musl",
    "build:linux-x64-musl-no-simd": "bun build ./src/index.js --compile --production --target=bun-linux-x64-musl-baseline --minify --outfile dist/bununban-linux-x64-musl-no-simd",
    "build:linux-arm64": "bun build ./src/index.js --compile --production --target=bun-linux-arm64 --minify --outfile dist/bununban-linux-arm64",
    "build:linux-arm64-musl": "bun build ./src/index.js --compile --production --target=bun-linux-arm64-musl --minify --outfile dist/bununban-linux-arm64-musl",
    "build:setup": "bun run build:setup:build-exe && bun run build:setup:patch-binary-subsystem && bun run build:setup:apply-manifest && bun run build:setup:pack-dll:generate-project && bun run build:setup:pack-dll:pack-files && bun run build:setup:clean",
    "build:setup:build-exe": "bun build --production --compile ./setup/index.js ./node_modules/@webui-dev/bun-webui/src/ffi_worker.ts --target=bun-windows-x64-modern --minify --outfile dist/bununban-windows-setup --windows-icon=\"./src/frontend/assets/favicon.ico\" --windows-hide-console --windows-title=bununban-setup --windows-publisher=Greezor --windows-version=0.3.0 --windows-description=Bununban",
    "build:setup:patch-binary-subsystem": "bun win-fix/modify-binary.js ./dist/bununban-windows-setup.exe",
    "build:setup:apply-manifest": "\"C:\\Program Files (x86)\\Windows Kits\\10\\bin\\10.0.26100.0\\x64\\mt.exe\" -manifest ./setup/win.manifest -outputresource:./dist/bununban-windows-setup.exe\\;#1",
    "build:setup:pack-dll:generate-project": "bun run ./setup/evb.js",
    "build:setup:pack-dll:pack-files": "\"C:\\Program Files (x86)\\Enigma Virtual Box\\enigmavbconsole.exe\" dist/project.evb",
    "build:setup:clean": "rm -rf dist/bununban-windows-setup.exe && rm -rf dist/project.evb && mv dist/bununban-windows-setup_boxed.exe dist/bununban-windows-setup.exe",
    "dockerize:arm64": "bun run build:linux-arm64 && docker run --name bununban --restart always --net=host --cap-add=NET_ADMIN -d -v ./dist:/bununban -w /bununban arm64v8/ubuntu:latest ./bununban-linux-arm64 --homedir=/bununban",
    "clear:dist": "rm -rf dist",
    "postinstall": "bun run ./postinstall.js"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@iconify-json/fa7-brands": "^1.2.2",
    "@iconify-json/fa7-solid": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.62",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify/utils": "^3.1.0",
    "@iconify/vue": "^5.0.0",
    "@primeuix/themes": "^2.0.2",
    "@vueuse/core": "^14.1.0",
    "@webui-dev/bun-webui": "^2.5.4",
    "jose": "^6.2.1",
    "monaco-editor": "^0.55.1",
    "nanotar": "^0.2.0",
    "primevue": "^4.5.4",
    "string-argv": "^0.3.2",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  }
}
